# Copy to .env and override for your environment. .env is gitignored.
# With no .env, the dev defaults in application.properties / compose.yaml are used.

# Database
DB_URL=jdbc:postgresql://localhost:5433/odontoflow
DB_USERNAME=postgres
DB_PASSWORD=change-me

# Auth — MUST be a long random value (>= 32 bytes) in production
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes
JWT_EXPIRATION=86400000

# Object storage (MinIO / S3)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=change-me
STORAGE_SECRET_KEY=change-me
STORAGE_BUCKET=odontoflow

# Billing: "fake" (offline, default) or "stripe" (stripe-mock / Stripe test mode)
BILLING_PROVIDER=fake
STRIPE_API_KEY=sk_test_xxx
STRIPE_BASE_URL=http://localhost:12111
